function renderLogs(studentId) {
  chrome.storage.local.get(["all_logs"], function(d) {
    var mine = (d.all_logs || []).filter(l => l.student_id === studentId)
    var list = $("logList")
    $("viol-count").textContent = mine.length
    list.innerHTML = mine.length
      ? mine.slice().reverse().slice(0, 20).map(l =>
          '<li>' +
          '<span class="dot" style="background:' + (COLOURS[l.violation_type] || "#6e7681") + '"></span>' +
          '<span class="vtype">' + violationLabel(l.violation_type) + '</span>' +
          '<span class="vtime">' + l.timestamp.slice(11, 19) + '</span>' +
          '</li>').join("")
      : '<li><span class="empty-note">No violations recorded.</span></li>'
  })
}
