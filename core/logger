var examActive  = false
var sessionInfo = {}

function loggerActivate(session) {
  examActive  = true
  sessionInfo = session || {}
}

function loggerDeactivate() {
  examActive  = false
  sessionInfo = {}
}

function log(type, detail) {
  if (!examActive) return
  var entry = {
    violation_type: type,
    detail:         detail || "",
    student_id:     sessionInfo.student_id   || "Unknown",
    student_name:   sessionInfo.student_name || "Unknown",
    exam_title:     sessionInfo.exam_title   || "Unknown",
    timestamp:      new Date().toISOString(),
    url:            location.href
  }
  try {
    chrome.storage.local.get(["all_logs"], function(d) {
      if (chrome.runtime.lastError) return
      var all = d.all_logs || []; all.push(entry)
      chrome.storage.local.set({ all_logs: all })
    })
  } catch(e) { return }
  try {
    if (!chrome.runtime || !chrome.runtime.id) return
    chrome.runtime.sendMessage({ action: "FB_WRITE_LOG", log: entry }, function() {
      if (chrome.runtime.lastError) { /* extension context gone, ignore */ }
    })
  } catch(e) { /* extension context invalidated, ignore */ }
}
