function storageGet(keys) {
  return new Promise(function(r) {
    if (typeof chrome !== "undefined" && chrome.storage && chrome.storage.local) {
      chrome.storage.local.get(keys, r)
    } else {
      r({})
    }
  })
}

function storageSet(data) {
  return new Promise(function(r) {
    if (typeof chrome !== "undefined" && chrome.storage && chrome.storage.local) {
      chrome.storage.local.set(data, r)
    } else {
      r()
    }
  })
}

async function getSession()      { var d = await storageGet(["student_session"]); return d.student_session }
async function getStudentLogin() { var d = await storageGet(["student_login"]);   return d.student_login }
async function getAllLogs()      { var d = await storageGet(["all_logs"]);         return d.all_logs || [] }

async function appendLog(entry) {
  var all = await getAllLogs()
  all.push(entry)
  return storageSet({ all_logs: all })
}
