{
  "manifest_version": 3,
  "name": "Anti-Cheating Extension",
  "version": "2.0",
  "description": "Student exam monitor with Firebase backend and separate teacher/student portals",

  "permissions": ["storage", "tabs"],

  "host_permissions": [
    "https://firestore.googleapis.com/*",
    "https://*.googleapis.com/*",
    "https://*.firebaseio.com/*"
  ],

  "action": {
    "default_popup": "portal.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "core.firebase.js",
        "core.storage.js",
        "core.logger.js",
        "monitors.tabfocus.js",
        "monitors.clipboard.js",
        "monitors.screenshot.js",
        "content.js"
      ]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "auth.css",
        "shared.css",
        "portal.css",
        "teacher.css",

        "portal.html",
        "portal.js",

        "student.html",
        "student.auth.js",
        "student.exam.js",
        "student.logs.js",
        "student.init.js",

        "teacher.html",
        "teacher.auth.js",
        "teacher.dashboard.js",
        "teacher.students.js",
        "teacher.render.js",
        "teacher.export.js",
        "teacher.init.js",

        "core.firebase.js",
        "core.storage.js",
        "core.logger.js",
        "monitors.tabfocus.js",
        "monitors.clipboard.js",
        "monitors.screenshot.js",

        "shared.ui.js",
        "shared.violations.js",
        "shared.csv.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}

